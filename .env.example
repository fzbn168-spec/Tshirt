# 全局环境配置示例 (Global Environment Configuration)
# 请将此文件复制为 .env 并根据您的环境填写具体值
# 注意：不要将包含真实密钥的 .env 文件提交到 Git

# -----------------------------------------------------------------------------
# 1. 数据库配置 (Database - PostgreSQL)
# -----------------------------------------------------------------------------
# 数据库连接字符串 (Prisma 使用)
# 格式: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=SCHEMA
DATABASE_URL="postgresql://admin:securepassword@postgres:5432/soletrade?schema=public"

# Postgres 容器配置 (仅 Docker 需要)
POSTGRES_USER="admin"
POSTGRES_PASSWORD="securepassword"
POSTGRES_DB="soletrade"

# -----------------------------------------------------------------------------
# 2. 后端服务 (Backend Service)
# -----------------------------------------------------------------------------
# 服务端口
PORT=3001

# JWT 密钥 (用于生成和验证 Token)
# ⚠️ 生产环境必须修改为强随机字符串 (如: openssl rand -hex 32)
JWT_SECRET="replace-with-secure-random-string"
JWT_EXPIRATION="1d"

# 前后端通信地址
FRONTEND_URL="http://localhost:3000"
BACKEND_URL="http://localhost:3001"

# Stripe 支付 (后端)
# 从 Stripe Dashboard 获取: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# 邮件服务 (SMTP)
# 用于发送注册验证、订单确认等邮件
SMTP_HOST="smtp.office365.com"
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER="your-email@outlook.com"
SMTP_PASS="your-app-password"
SMTP_FROM='"SoleTrade Support" <your-email@outlook.com>'
# 管理员邮箱 (接收系统通知)
ADMIN_EMAIL="admin@yourdomain.com"

# 社交登录 (OAuth2)
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_CALLBACK_URL="http://localhost:3001/auth/google/callback"

FACEBOOK_APP_ID="your-facebook-app-id"
FACEBOOK_APP_SECRET="your-facebook-app-secret"
FACEBOOK_CALLBACK_URL="http://localhost:3001/auth/facebook/callback"

# -----------------------------------------------------------------------------
# 3. 前端商城 (Frontend Storefront)
# -----------------------------------------------------------------------------
# API 地址 (必须以 NEXT_PUBLIC_ 开头)
NEXT_PUBLIC_API_URL="http://localhost:3001"

# Stripe 公钥 (前端使用)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# WhatsApp 客服号码 (格式: 1234567890)
NEXT_PUBLIC_WHATSAPP_NUMBER="1234567890"

# 银行转账信息 (前端展示)
NEXT_PUBLIC_BANK_NAME="Bank of America"
NEXT_PUBLIC_BANK_ACCOUNT_NAME="SoleTrade Inc."
NEXT_PUBLIC_BANK_ACCOUNT_NO="1234567890"
NEXT_PUBLIC_BANK_SWIFT_CODE="BOFAUS3N"
NEXT_PUBLIC_BANK_ADDRESS="123 Innovation Dr, Tech City, USA"

# 西联汇款信息 (前端展示)
NEXT_PUBLIC_WU_RECEIVER_NAME="John Doe"
NEXT_PUBLIC_WU_CITY="Tech City"
NEXT_PUBLIC_WU_COUNTRY="USA"

# -----------------------------------------------------------------------------
# 4. 后端支付信息 (Backend Payment Info)
# -----------------------------------------------------------------------------
# 用于生成 PDF 发票中的银行信息 (通常与前端一致，但用于服务端渲染)
BANK_NAME="Bank of America"
BANK_ACCOUNT_NAME="SoleTrade Inc."
BANK_ACCOUNT_NO="1234567890"
BANK_SWIFT_CODE="BOFAUS3N"
BANK_ADDRESS="123 Innovation Dr, Tech City, USA"

WU_RECEIVER_NAME="John Doe"
WU_CITY="Tech City"
WU_COUNTRY="USA"

# -----------------------------------------------------------------------------
# 5. 管理后台 (Admin Panel)
# -----------------------------------------------------------------------------
# API 地址 (复用前端变量名或独立配置)
# NEXT_PUBLIC_API_URL 会自动被 Admin Panel 读取

# Facebook 登录配置 (Facebook Auth)
FACEBOOK_APP_ID="your-facebook-app-id"
FACEBOOK_APP_SECRET="your-facebook-app-secret"
FACEBOOK_CALLBACK_URL="http://localhost:3001/auth/facebook/callback"
